  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "view-in-github",
        "colab_type": "text"
      },
      "source": [
        "<a href=\"https://colab.research.google.com/github/Gustavcheung/-3qvh-khbhk/blob/main/missile_defense.mp4\" target=\"_parent\"><img src=\"https://colab.research.google.com/assets/colab-badge.svg\" alt=\"Open In Colab\"/></a>"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Install required packages\n",
        "!pip install -q numpy matplotlib ipywidgets\n",
        "\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from matplotlib import animation\n",
        "from IPython.display import HTML, display\n",
        "import ipywidgets as widgets\n",
        "from mpl_toolkits.mplot3d import Axes3D\n",
        "import time\n",
        "\n",
        "# Set up the figure and 3D axis\n",
        "fig = plt.figure(figsize=(12, 8))\n",
        "ax = fig.add_subplot(111, projection='3d')\n",
        "\n",
        "# Simulation parameters\n",
        "t_max = 10  # maximum simulation time\n",
        "dt = 0.05   # time step\n",
        "n_frames = int(t_max / dt)\n",
        "\n",
        "# Colors\n",
        "GROUND_COLOR = 'saddlebrown'\n",
        "INCOMING_COLOR = 'red'\n",
        "INTERCEPTOR_COLOR = 'blue'\n",
        "EXPLOSION_COLOR = 'orange'\n",
        "TRAIL_COLOR = 'gray'\n",
        "\n",
        "# Create ground (a simple plane)\n",
        "x_ground = np.linspace(-10, 10, 20)\n",
        "y_ground = np.linspace(-10, 10, 20)\n",
        "X_ground, Y_ground = np.meshgrid(x_ground, y_ground)\n",
        "Z_ground = np.zeros_like(X_ground)\n",
        "\n",
        "# Initialize trajectories\n",
        "def init_trajectories():\n",
        "    # Incoming missile: starts high, targets ground near origin\n",
        "    incoming_start = np.array([8, 5, 15])\n",
        "    incoming_target = np.array([2, 1, 0])\n",
        "\n",
        "    # Interceptor: launches from ground near origin\n",
        "    interceptor_start = np.array([-3, -2, 0])\n",
        "\n",
        "    # Calculate direction vectors\n",
        "    incoming_dir = incoming_target - incoming_start\n",
        "    incoming_dir = incoming_dir / np.linalg.norm(incoming_dir)\n",
        "\n",
        "    # Interceptor aims to intercept at some point\n",
        "    intercept_time = 4.5  # time when interception should occur\n",
        "    intercept_point = incoming_start + incoming_dir * 7  # estimated intercept point\n",
        "\n",
        "    interceptor_dir = intercept_point - interceptor_start\n",
        "    interceptor_dir = interceptor_dir / np.linalg.norm(interceptor_dir)\n",
        "\n",
        "    # Speeds\n",
        "    v_incoming = 2.0\n",
        "    v_interceptor = 3.0\n",
        "\n",
        "    # Generate trajectories\n",
        "    t = np.arange(0, t_max, dt)\n",
        "    incoming_traj = []\n",
        "    interceptor_traj = []\n",
        "\n",
        "    for time in t:\n",
        "        # Incoming missile position\n",
        "        incoming_pos = incoming_start + incoming_dir * v_incoming * time\n",
        "        # Stop at ground\n",
        "        if incoming_pos[2] < 0:\n",
        "            incoming_pos[2] = 0\n",
        "        incoming_traj.append(incoming_pos)\n",
        "\n",
        "        # Interceptor missile position\n",
        "        interceptor_pos = interceptor_start + interceptor_dir * v_interceptor * time\n",
        "        # Keep above ground\n",
        "        if interceptor_pos[2] < 0:\n",
        "            interceptor_pos[2] = 0\n",
        "        interceptor_traj.append(interceptor_pos)\n",
        "\n",
        "    return np.array(incoming_traj), np.array(interceptor_traj), intercept_time\n",
        "\n",
        "# Initialize trajectories\n",
        "incoming_traj, interceptor_traj, intercept_time = init_trajectories()\n",
        "\n",
        "# Calculate explosion point (where missiles are closest)\n",
        "def find_explosion_point():\n",
        "    min_dist = float('inf')\n",
        "    explosion_frame = 0\n",
        "\n",
        "    for i in range(len(incoming_traj)):\n",
        "        dist = np.linalg.norm(incoming_traj[i] - interceptor_traj[i])\n",
        "        if dist < min_dist:\n",
        "            min_dist = dist\n",
        "            explosion_frame = i\n",
        "\n",
        "    return explosion_frame, min_dist\n",
        "\n",
        "explosion_frame, min_dist = find_explosion_point()\n",
        "explosion_pos = incoming_traj[explosion_frame]\n",
        "\n",
        "# Animation function\n",
        "def animate(frame):\n",
        "    ax.clear()\n",
        "\n",
        "    # Set labels and title\n",
        "    ax.set_xlabel('X (km)')\n",
        "    ax.set_ylabel('Y (km)')\n",
        "    ax.set_zlabel('Z (km)')\n",
        "    ax.set_title(f'Missile Defense Simulation - Frame {frame}/{n_frames}')\n",
        "\n",
        "    # Set axis limits\n",
        "    ax.set_xlim(-10, 10)\n",
        "    ax.set_ylim(-10, 10)\n",
        "    ax.set_zlim(0, 20)\n",
        "\n",
        "    # Plot ground\n",
        "    ax.plot_surface(X_ground, Y_ground, Z_ground, alpha=0.3, color=GROUND_COLOR)\n",
        "\n",
        "    # Plot city/target area\n",
        "    ax.scatter([2, 1], [1, -1], [0, 0], color='green', s=100, marker='^', label='Targets')\n",
        "\n",
        "    # Plot trajectories up to current frame\n",
        "    if frame > 0:\n",
        "        # Incoming missile trail\n",
        "        ax.plot(incoming_traj[:frame, 0],\n",
        "                incoming_traj[:frame, 1],\n",
        "                incoming_traj[:frame, 2],\n",
        "                color=INCOMING_COLOR, alpha=0.3, linewidth=1, label='Incoming trail')\n",
        "\n",
        "        # Interceptor missile trail\n",
        "        ax.plot(interceptor_traj[:frame, 0],\n",
        "                interceptor_traj[:frame, 1],\n",
        "                interceptor_traj[:frame, 2],\n",
        "                color=INTERCEPTOR_COLOR, alpha=0.3, linewidth=1, label='Interceptor trail')\n",
        "\n",
        "    # Plot current positions\n",
        "    if frame < len(incoming_traj):\n",
        "        # Incoming missile\n",
        "        if frame < explosion_frame:\n",
        "            ax.scatter(incoming_traj[frame, 0],\n",
        "                      incoming_traj[frame, 1],\n",
        "                      incoming_traj[frame, 2],\n",
        "                      color=INCOMING_COLOR, s=200, marker='o', label='Incoming Missile')\n",
        "\n",
        "            # Interceptor missile\n",
        "            ax.scatter(interceptor_traj[frame, 0],\n",
        "                      interceptor_traj[frame, 1],\n",
        "                      interceptor_traj[frame, 2],\n",
        "                      color=INTERCEPTOR_COLOR, s=200, marker='^', label='Interceptor')\n",
        "\n",
        "            # Draw line between missiles (for visual effect)\n",
        "            if frame > explosion_frame - 10:\n",
        "                ax.plot([incoming_traj[frame, 0], interceptor_traj[frame, 0]],\n",
        "                       [incoming_traj[frame, 1], interceptor_traj[frame, 1]],\n",
        "                       [incoming_traj[frame, 2], interceptor_traj[frame, 2]],\n",
        "                       color='yellow', linestyle='--', alpha=0.5)\n",
        "\n",
        "        # Explosion effect\n",
        "        elif frame >= explosion_frame and frame < explosion_frame + 15:\n",
        "            # Draw explosion\n",
        "            explosion_size = 100 + (frame - explosion_frame) * 50\n",
        "            ax.scatter(explosion_pos[0], explosion_pos[1], explosion_pos[2],\n",
        "                      color=EXPLOSION_COLOR, s=explosion_size, alpha=0.7, marker='*', label='EXPLOSION!')\n",
        "\n",
        "            # Draw explosion debris\n",
        "            for i in range(5):\n",
        "                offset = (frame - explosion_frame) * 0.1\n",
        "                ax.scatter(explosion_pos[0] + np.sin(i*2) * offset,\n",
        "                          explosion_pos[1] + np.cos(i*2) * offset,\n",
        "                          explosion_pos[2] + np.sin(i*3) * offset,\n",
        "                          color='yellow', s=50, alpha=0.5)\n",
        "\n",
        "    # Add legend\n",
        "    ax.legend(loc='upper right')\n",
        "\n",
        "    # Add text information\n",
        "    if frame < explosion_frame:\n",
        "        distance = np.linalg.norm(incoming_traj[frame] - interceptor_traj[frame])\n",
        "        ax.text2D(0.02, 0.98, f'Distance: {distance:.2f} km',\n",
        "                 transform=ax.transAxes, fontsize=12, verticalalignment='top',\n",
        "                 bbox=dict(boxstyle='round', facecolor='wheat', alpha=0.5))\n",
        "\n",
        "    ax.view_init(elev=20, azim=frame/2)  # Rotate view for better 3D effect\n",
        "\n",
        "# Create animation\n",
        "print(\"Creating animation...\")\n",
        "anim = animation.FuncAnimation(fig, animate, frames=n_frames, interval=50, repeat=True)\n",
        "\n",
        "# Display in Colab\n",
        "plt.close()  # Prevent duplicate display\n",
        "html_video = anim.to_html5_video()\n",
        "display(HTML(html_video))\n",
        "\n",
        "# Print simulation info\n",
        "print(f\"\\nSimulation Statistics:\")\n",
        "print(f\"Interception occurred at frame: {explosion_frame}\")\n",
        "print(f\"Minimum distance between missiles: {min_dist:.2f} km\")\n",
        "print(f\"Explosion position: ({explosion_pos[0]:.1f}, {explosion_pos[1]:.1f}, {explosion_pos[2]:.1f}) km\")\n",
        "\n",
        "# Create an interactive version with widgets\n",
        "print(\"\\n\" + \"=\"*50)\n",
        "print(\"Interactive Control Panel\")\n",
        "print(\"=\"*50)\n",
        "\n",
        "# Interactive function\n",
        "def interactive_simulation(launch_angle=45, interceptor_speed=3.0, intercept_height=5):\n",
        "    # Recalculate trajectories based on parameters\n",
        "    incoming_start = np.array([8, 5, 15])\n",
        "    incoming_target = np.array([2, 1, 0])\n",
        "    interceptor_start = np.array([-3, -2, 0])\n",
        "\n",
        "    # Calculate directions\n",
        "    incoming_dir = incoming_target - incoming_start\n",
        "    incoming_dir = incoming_dir / np.linalg.norm(incoming_dir)\n",
        "\n",
        "    # Adjust interceptor based on parameters\n",
        "    angle_rad = np.radians(launch_angle)\n",
        "    intercept_point = np.array([2, 1, intercept_height])\n",
        "\n",
        "    interceptor_dir = intercept_point - interceptor_start\n",
        "    interceptor_dir = interceptor_dir / np.linalg.norm(interceptor_dir)\n",
        "\n",
        "    # Speeds\n",
        "    v_incoming = 2.0\n",
        "    v_interceptor = interceptor_speed\n",
        "\n",
        "    # Generate trajectories\n",
        "    t = np.arange(0, t_max, dt)\n",
        "    incoming_traj = []\n",
        "    interceptor_traj = []\n",
        "\n",
        "    for time in t:\n",
        "        incoming_pos = incoming_start + incoming_dir * v_incoming * time\n",
        "        if incoming_pos[2] < 0:\n",
        "            incoming_pos[2] = 0\n",
        "        incoming_traj.append(incoming_pos)\n",
        "\n",
        "        interceptor_pos = interceptor_start + interceptor_dir * v_interceptor * time\n",
        "        if interceptor_pos[2] < 0:\n",
        "            interceptor_pos[2] = 0\n",
        "        interceptor_traj.append(interceptor_pos)\n",
        "\n",
        "    incoming_traj = np.array(incoming_traj)\n",
        "    interceptor_traj = np.array(interceptor_traj)\n",
        "\n",
        "    # Find closest approach\n",
        "    min_dist = float('inf')\n",
        "    explosion_frame = 0\n",
        "    for i in range(len(incoming_traj)):\n",
        "        dist = np.linalg.norm(incoming_traj[i] - interceptor_traj[i])\n",
        "        if dist < min_dist:\n",
        "            min_dist = dist\n",
        "            explosion_frame = i\n",
        "\n",
        "    # Create new figure\n",
        "    fig2 = plt.figure(figsize=(10, 8))\n",
        "    ax2 = fig2.add_subplot(111, projection='3d')\n",
        "\n",
        "    # Plot everything\n",
        "    ax2.plot_surface(X_ground, Y_ground, Z_ground, alpha=0.3, color=GROUND_COLOR)\n",
        "    ax2.scatter([2, 1], [1, -1], [0, 0], color='green', s=100, marker='^')\n",
        "\n",
        "    # Plot trajectories\n",
        "    ax2.plot(incoming_traj[:, 0], incoming_traj[:, 1], incoming_traj[:, 2],\n",
        "             color=INCOMING_COLOR, linewidth=2, label='Incoming Missile')\n",
        "    ax2.plot(interceptor_traj[:, 0], interceptor_traj[:, 1], interceptor_traj[:, 2],\n",
        "             color=INTERCEPTOR_COLOR, linewidth=2, label='Interceptor')\n",
        "\n",
        "    # Mark explosion\n",
        "    if explosion_frame < len(incoming_traj):\n",
        "        ax2.scatter(incoming_traj[explosion_frame, 0],\n",
        "                   incoming_traj[explosion_frame, 1],\n",
        "                   incoming_traj[explosion_frame, 2],\n",
        "                   color=EXPLOSION_COLOR, s=300, marker='*', label='Interception Point')\n",
        "\n",
        "    ax2.set_xlabel('X (km)')\n",
        "    ax2.set_ylabel('Y (km)')\n",
        "    ax2.set_zlabel('Z (km)')\n",
        "    ax2.set_title(f'Missile Defense - Interception at height {incoming_traj[explosion_frame, 2]:.1f} km')\n",
        "    ax2.set_xlim(-10, 10)\n",
        "    ax2.set_ylim(-10, 10)\n",
        "    ax2.set_zlim(0, 20)\n",
        "    ax2.legend()\n",
        "    ax2.view_init(elev=20, azim=45)\n",
        "\n",
        "    plt.show()\n",
        "\n",
        "    print(f\"Minimum distance: {min_dist:.2f} km\")\n",
        "    print(f\"Interception height: {incoming_traj[explosion_frame, 2]:.1f} km\")\n",
        "\n",
        "# Create interactive widgets\n",
        "print(\"\\nAdjust parameters to see different interception scenarios:\")\n",
        "interactive_plot = widgets.interactive(interactive_simulation,\n",
        "                                       launch_angle=widgets.IntSlider(min=0, max=90, step=5, value=45, description='Launch Angle:'),\n",
        "                                       interceptor_speed=widgets.FloatSlider(min=1.0, max=5.0, step=0.2, value=3.0, description='Interceptor Speed:'),\n",
        "                                       intercept_height=widgets.FloatSlider(min=1, max=15, step=1, value=5, description='Target Height:'))\n",
        "\n",
        "display(interactive_plot)"
      ],
